{
    "name": "taskdesk-server",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "tsx watch index.ts",
        "build": "pnpm install --include=dev && tsc -p tsconfig.json",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "dependencies": {
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.3",
        "@types/node": "^24.7.2",
        "@types/pg": "^8.11.10",
        "@types/uuid": "^9.0.8",
        "@types/ws": "^8.18.1",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dev": "^0.1.3",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "pg": "^8.13.0",
        "uuid": "^9.0.1",
        "ws": "^8.17.0"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.59.1",
        "@typescript-eslint/parser": "^8.59.1",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.3",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3"
    }
}